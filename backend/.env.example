# ==========================================
# SMARTSTAY HUB - BACKEND CONFIGURATION
# ==========================================

# SERVER CONFIG
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# DATABASE
MONGO_URI=mongodb://127.0.0.1:27017/smartstay-hub-db
# Set to true to use in-memory DB if local Mongo fails (Dev only)
ALLOW_MOCK_DB=false

# SECURITY (JWT)
# Use a long random string (32+ chars) for production
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE_SECONDS=604800

# CLOUDINARY (Image Storage)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# RAZORPAY (Payments)
# Get these from: https://dashboard.razorpay.com/app/website-app-settings/api-keys
RAZORPAY_KEY_ID=rzp_test_SsJKmVsyRrXTwY
RAZORPAY_KEY_SECRET=E4Z7gQie76x7YP11wQ2UeCeQ4

# FIREBASE (Authentication & Push Notifications)
# Option 1: Path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT=./config/serviceAccountKey.json
# Option 2: Paste your service account JSON as a string (useful for Heroku/Docker)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}

# ADMIN CONFIG
ADMIN_MOBILE=8688946165

# COOKIE CONFIG
# In seconds (e.g., 604800 for 7 days)
COOKIE_EXPIRE=604800
